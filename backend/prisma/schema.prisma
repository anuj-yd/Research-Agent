generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  
  searchHistory SearchHistory[]
  reports       InvestmentReport[]
}

model SearchHistory {
  id        Int      @id @default(autoincrement())
  query     String
  createdAt DateTime @default(now())
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model InvestmentReport {
  id        Int      @id @default(autoincrement())
  ticker    String
  score     Int
  swot      Json     // Store the strengths, weaknesses, opportunities, threats
  createdAt DateTime @default(now())
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}
